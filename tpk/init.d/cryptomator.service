[Unit]
Description=Cryptomator Vault Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=-/usr/local/app/cryptomator/config/cryptomator.env
ExecStart=/usr/local/app/cryptomator/bin/cryptomator
ExecStop=/bin/kill -TERM $MAINPID
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
